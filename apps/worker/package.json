    "generate:drafts": "tsx src/index.ts generate-drafts",
    "generate-three-d-previews": "tsx src/index.ts generate-three-d-previews",
    "ingest": "tsx src/index.ts ingest",
    "ingest:jlcparts": "tsx src/index.ts ingest jlcparts",
    "ingest:octopart": "tsx src/index.ts ingest octopart",
