    "test": "node ../../scripts/run-tests.mjs src",
    "validate-footprints": "tsx src/index.ts validate-footprints",
    "validate-symbol-pin-counts": "tsx src/index.ts validate-symbol-pin-counts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
