{
  "name": "@ee-library/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./export-bundle-verification": "./src/export-bundle-verification.ts",
    "./provider-acquisition-jobs": "./src/provider-acquisition-jobs.ts",
    "./provider-enrichment-jobs": "./src/provider-enrichment-jobs.ts",
