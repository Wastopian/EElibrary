# File header: Template for the team server environment file (.env.team).
#
# Do not edit this template on a live server. Run `node scripts/setup-team-server.mjs`
# instead — it copies this file to .env.team and fills every CHANGE_ME with a freshly
# generated value so no two team servers share secrets.
#
# .env.team is read by every service in compose.team.yaml and must never be committed.

# --- Database (the DATABASE_URL password must match POSTGRES_PASSWORD) -------------------
POSTGRES_DB=ee_library
POSTGRES_USER=ee_library
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgres://ee_library:CHANGE_ME_DB_PASSWORD@postgres:5432/ee_library

# --- Sessions and sign-in -----------------------------------------------------------------
# AUTH_SECRET signs every session. 32+ random characters; the API refuses to start without it.
AUTH_SECRET=CHANGE_ME_AUTH_SECRET
# The web app sits behind the published compose port, so Auth.js must trust the request host.
AUTH_TRUST_HOST=true
# New accounts require this code on the sign-up page. Share it only with your team.
# Leave the value empty to allow open sign-up (only safe on a trusted, private network).
EE_LIBRARY_SIGNUP_INVITE_CODE=CHANGE_ME_INVITE_CODE

# --- Service wiring (in-stack addresses; normally leave as-is) -----------------------------
EE_LIBRARY_API_BASE_URL=http://api:4000
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage
EE_LIBRARY_PROJECT_FILES_ROOT=/data/project-files
EE_LIBRARY_VENDOR_NOTES_ROOT=/data/vendor-notes

# --- Optional: free provider credentials (leave blank to run without provider intake) ------
#DIGIKEY_CLIENT_ID=
#DIGIKEY_CLIENT_SECRET=
#MOUSER_API_KEY=
#KICAD_LIBRARY_ROOT=

# --- Optional: paid Octopart/Nexar aggregator (stays inert unless configured) --------------
#NEXAR_ACCESS_TOKEN=
#NEXAR_CLIENT_ID=
#NEXAR_CLIENT_SECRET=

# --- Optional: export bundle signing (Ed25519 PEM) -----------------------------------------
#EE_LIBRARY_BUNDLE_SIGNING_KEY=
#EE_LIBRARY_BUNDLE_VERIFICATION_KEY=
