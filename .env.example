# Local API service port used by apps/api.
API_PORT=4000

# Web port used by apps/web (Next dev server). Defaults to 3000.
WEB_PORT=3000

# Web server-side data access URL for apps/api. Use 127.0.0.1 (not localhost) to avoid
# IPv4/IPv6 resolution surprises on Windows/Node 20.
EE_LIBRARY_API_BASE_URL=http://127.0.0.1:4000

# Local Postgres connection for the Phase 0 database container.
DATABASE_URL=postgres://ee_library:ee_library@localhost:5432/ee_library

# Local Redis connection for future worker queues.
REDIS_URL=redis://localhost:6379

# Local S3-compatible object storage endpoint for datasheets and CAD files (MinIO via compose.yaml).
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=ee-library-assets
OBJECT_STORAGE_ACCESS_KEY=ee_library
OBJECT_STORAGE_SECRET_KEY=ee_library_secret

# Optional local fallback path for storage when MinIO is unavailable. Not currently consumed
# by code but reserved for an offline-only mode in a later phase.
# OBJECT_STORAGE_LOCAL_PATH=./.local-storage

# Local-development hint flags. The web app's WorkerStatusBanner prints actionable copy when
# the API is unreachable; that copy is more verbose when LOCAL_DEV is true.
LOCAL_DEV=true

# Auth secret used by session/cookie signing. Must be at least 32 characters.
# `npm run setup:dev` generates one (48 random bytes, base64url) if this is empty.
AUTH_SECRET=
