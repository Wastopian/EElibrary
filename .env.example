# Bearer-token signing secret shared by apps/api and apps/web. Must be at least 32 bytes;
# generate with `openssl rand -hex 32`. The API refuses to start without this set, and
# every JWT verification refuses every token, so missing-secret deploys fail closed
# instead of accepting tokens forged against a zero-byte HMAC key.
AUTH_SECRET=

# Local API service port used by apps/api.
API_PORT=4000

# Web port used by apps/web (Next dev server). Defaults to 3000.
WEB_PORT=3000

# Web server-side data access URL for apps/api. Use 127.0.0.1 (not localhost) to avoid
# IPv4/IPv6 resolution surprises on Windows/Node 20.
EE_LIBRARY_API_BASE_URL=http://127.0.0.1:4000

# Local Postgres connection for the Phase 0 database container.
# POSTGRES_PORT controls the host-side Docker bind port (container stays on 5432).
POSTGRES_PORT=5432
DATABASE_URL=postgres://ee_library:ee_library@localhost:5432/ee_library

# --- Public component data providers (intake only) -------------------------
# Provider data is input, not truth. None of the keys below are required to run
# EE Library; configure the free distributor providers first and treat Nexar as
# an optional paid aggregator only when a team already pays for it.

# Optional rich aggregator. Octopart data is accessed through the paid Nexar
# GraphQL API, so it is opt-in and never the default import source. Set either a
# short-lived portal token for local testing or the OAuth client credentials.
# NEXAR_CLIENT_ID=
# NEXAR_CLIENT_SECRET=
# NEXAR_ACCESS_TOKEN=
# NEXAR_GRAPHQL_URL=https://api.nexar.com/graphql
# NEXAR_TOKEN_URL=https://identity.nexar.com/connect/token

# Free / distributor providers. DigiKey uses an OAuth2 client-credentials app
# (register at https://developer.digikey.com); Mouser uses a single search API
# key (request at https://www.mouser.com/api-hub/).
# DIGIKEY_CLIENT_ID=
# DIGIKEY_CLIENT_SECRET=
# DIGIKEY_REDIRECT_URI=
# DIGIKEY_API_BASE_URL=https://api.digikey.com
# MOUSER_API_KEY=
# MOUSER_API_BASE_URL=https://api.mouser.com

# Local public CAD index. Point this at a checkout of public KiCad libraries
# (.kicad_sym / .kicad_mod / .step) to index footprints, symbols, and models
# from disk with no network calls or credentials.
KICAD_LIBRARY_ROOT=./data/providers/kicad

# Local Redis connection for future worker queues.
# REDIS_PORT controls the host-side Docker bind port (container stays on 6379).
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Local S3-compatible object storage endpoint for datasheets and CAD files.
# OBJECT_STORAGE_PORT and OBJECT_STORAGE_CONSOLE_PORT control host-side Docker bind
# ports (container stays on 9000/9001). If those ports are in use on your machine,
# change these values and update OBJECT_STORAGE_ENDPOINT to match.
OBJECT_STORAGE_PORT=9000
OBJECT_STORAGE_CONSOLE_PORT=9001
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=ee-library-assets
OBJECT_STORAGE_ACCESS_KEY=ee_library
OBJECT_STORAGE_SECRET_KEY=ee_library_secret

# Local-development hint flag. The web app's WorkerStatusBanner prints actionable copy
# (exact commands and the URL it tried) when LOCAL_DEV is true and the API is unreachable.
LOCAL_DEV=true

# Optional smoke-test strictness:
# - EE_LIBRARY_WEB_BASE_URL defaults to http://127.0.0.1:${WEB_PORT}
# - EE_SMOKE_REQUIRE_WEB=1 upgrades web route checks in `npm run smoke:local`
#   from warnings to failures.
EE_LIBRARY_WEB_BASE_URL=http://127.0.0.1:3000
EE_SMOKE_REQUIRE_WEB=0

# Project file mirror: where each project's parts list, internal hardware, datasheets,
# and 3D models live on disk. Each project gets its own subfolder (named by project
# key) with five children: `parts-list/`, `hardware/`, `datasheets/`, `models/`,
# and `notes/`. Engineers can drop files into these folders directly and refresh the
# project page to see them.
#
# - Defaults to `<user-home>/EE-Library/projects` when unset.
# - Set to `off` to disable the panel without code changes.
# - Use an absolute path for production deploys with mounted volumes.
# EE_LIBRARY_PROJECT_FILES_ROOT=

# Custom design scanner prefixes. Defaults to PTA, PCA, and ICD. Real folders inside
# `hardware/` also introduce prefixes automatically; set this when parts lists may mention
# a custom design family before its folder exists.
# EE_LIBRARY_CUSTOM_HARDWARE_PREFIXES=PTA,PCA,ICD

# Vendor notebook: where supplier records (PCB fabs, sheet metal shops, machinists,
# finishers, electronics assembly, distributors) live on disk. Each vendor lives at
# `<root>/<category>/<slug>/` with `notes/` and `files/` subfolders. The site reads
# what is on disk; engineers can also drop files in directly.
#
# - Defaults to `<user-home>/EE-Library/vendors` when unset.
# - Set to `off` to hide the vendor pages without code changes.
# EE_LIBRARY_VENDOR_NOTES_ROOT=
