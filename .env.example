# Bearer-token signing secret shared by apps/api and apps/web. Must be at least 32 bytes;
# generate with `openssl rand -hex 32`. The API refuses to start without this set, and
# every JWT verification refuses every token, so missing-secret deploys fail closed
# instead of accepting tokens forged against a zero-byte HMAC key.
AUTH_SECRET=

# Local API service port used by apps/api.
API_PORT=4000

# Web server-side data access URL for apps/api.
EE_LIBRARY_API_BASE_URL=http://127.0.0.1:4000

# Local Postgres connection for the Phase 0 database container.
DATABASE_URL=postgres://ee_library:ee_library@localhost:5432/ee_library

# Local Redis connection for future worker queues.
REDIS_URL=redis://localhost:6379

# Local S3-compatible object storage endpoint for datasheets and CAD files.
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=ee-library-assets
OBJECT_STORAGE_ACCESS_KEY=ee_library
OBJECT_STORAGE_SECRET_KEY=ee_library_secret
