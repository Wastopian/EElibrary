{
  "name": "ee-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "db:migrate": "node scripts/with-local-env.mjs node scripts/db-migrate.mjs",
    "db:reset": "node scripts/with-local-env.mjs node scripts/db-reset.mjs",
    "db:status": "node scripts/with-local-env.mjs --warn-only node scripts/db-status.mjs",
    "dev": "node scripts/ensure-local-infra.mjs && node scripts/with-local-env.mjs npx concurrently -n api,web -c green,blue \"npm:dev:api:nowrap\" \"npm:dev:web:nowrap\"",
    "dev:api": "node scripts/ensure-local-infra.mjs && node scripts/with-local-env.mjs npm run dev -w @ee-library/api",
    "dev:api:nowrap": "npm run dev -w @ee-library/api",
    "dev:web": "node scripts/with-local-env.mjs npm run dev -w @ee-library/web",
    "dev:web:nowrap": "npm run dev -w @ee-library/web",
    "dev:worker": "node scripts/with-local-env.mjs npm run dev -w @ee-library/worker",
    "extract:project-documents": "node scripts/with-local-env.mjs npm run extract-project-documents -w @ee-library/worker",
    "generate:drafts": "node scripts/with-local-env.mjs npm run generate:drafts -w @ee-library/worker",
    "ingest:local": "node scripts/with-local-env.mjs npm run ingest -w @ee-library/worker",
    "ingest:jlcparts": "node scripts/with-local-env.mjs npm run ingest:jlcparts -w @ee-library/worker",
    "ingest:octopart": "node scripts/with-local-env.mjs npm run ingest:octopart -w @ee-library/worker",
    "imports:providers": "node scripts/with-local-env.mjs npm run imports -w @ee-library/worker",
    "operations:worker": "node scripts/with-local-env.mjs npm run operations -w @ee-library/worker",
    "refresh:supply-offers": "node scripts/with-local-env.mjs npm run refresh-supply-offers -w @ee-library/worker",
    "lint": "npm run lint --workspaces",
    "seed:admin": "node scripts/with-local-env.mjs node scripts/seed-admin.mjs",
    "seed:demo-project": "node scripts/with-local-env.mjs node scripts/seed-demo-project.mjs",
    "setup:dev": "node scripts/setup-dev.mjs",
    "setup:team": "node scripts/setup-team-server.mjs",
    "smoke:local": "node scripts/with-local-env.mjs --warn-only node scripts/smoke-local.mjs",
    "team:backup": "node scripts/team-backup.mjs",
    "team:restore": "node scripts/team-restore.mjs",
    "team:smoke": "node scripts/team-stack-smoke.mjs",
    "test": "npm run test --workspaces --if-present && npm run test:scripts",
    "test:scripts": "node --test scripts/__tests__",
    "typecheck": "npm run typecheck --workspaces"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.1",
    "pg-mem": "^3.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
