{
  "name": "ee-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently -n api,web -c green,blue \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @ee-library/api",
    "dev:web": "npm run dev -w @ee-library/web",
    "dev:worker": "npm run dev -w @ee-library/worker",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
